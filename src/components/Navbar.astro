---
interface NavLink {
  label: string;
  href: string;
}

const leftLinks: NavLink[] = [
  { label: 'Productos', href: '/products' },
  { label: 'Eventos', href: '/events' },
];

const rightLinks: NavLink[] = [
  { label: 'Contacto', href: '/contact' },
  { label: 'Conócenos', href: '/about' },
];

const allLinks = [...leftLinks, ...rightLinks];
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => currentPath === (href.replace(/\/$/, '') || '/');

const desktopLinkClass = (href: string) => [
  'relative rounded-full px-3 py-1.5 text-base font-bold tracking-wide transition duration-150',
  isActive(href)
    ? 'border-2 border-primary bg-primary text-white shadow-[3px_3px_0_#f9a2b4]'
    : 'text-copy hover:bg-secondary/45 hover:text-primary',
];

const mobileLinkClass = (href: string) => [
  'block text-center font-[Caveat] text-[2.35rem] font-bold leading-none no-underline transition duration-150',
  isActive(href) ? 'text-primary' : 'text-primary/45 hover:text-primary',
];
---

<header class="fixed left-0 right-0 top-0 md:z-50 z-1000 bg-cream/95 pt-2 font-sans backdrop-blur">
  <nav class="relative mx-auto flex h-16 max-w-5xl items-center justify-between px-6 md:grid md:grid-cols-[1fr_auto_1fr]">
    <ul class="m-0 hidden list-none items-center justify-end gap-5 p-0 md:flex">
      {leftLinks.map(({ label, href }) => (
        <li>
          <a href={href} aria-current={isActive(href) ? 'page' : undefined} class:list={[desktopLinkClass(href), 'motion-press']}>
            {label}
          </a>
        </li>
      ))}
    </ul>

    <a
      href="/"
      class="absolute left-1/2 z-[70] -translate-x-1/2 text-center font-[Caveat] text-[3rem] font-bold leading-none tracking-tight text-primary no-underline transition-opacity duration-150 hover:opacity-70 md:static md:translate-x-0 md:px-10"
    >
      Dulce Aurora
    </a>

    <ul class="m-0 hidden list-none items-center justify-start gap-5 p-0 md:flex">
      {rightLinks.map(({ label, href }) => (
        <li>
          <a href={href} aria-current={isActive(href) ? 'page' : undefined} class:list={[desktopLinkClass(href), 'motion-press']}>
            {label}
          </a>
        </li>
      ))}
    </ul>

    <button
      id="hamburger-btn"
      aria-label="Abrir menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="relative z-[70] ml-auto flex h-[18px] w-7 cursor-pointer flex-col justify-between border-0 bg-transparent p-0 md:hidden"
    >
      <span id="h-line1" class="block h-0.5 w-full origin-center rounded bg-primary transition-all duration-300"></span>
      <span id="h-line2" class="block h-0.5 w-full rounded bg-primary transition-all duration-300"></span>
      <span id="h-line3" class="block h-0.5 w-full origin-center rounded bg-primary transition-all duration-300"></span>
    </button>
  </nav>

  <div
    id="mobile-menu"
    aria-hidden="true"
    class="fixed inset-0 flex min-h-[100svh] flex-col bg-cream/98 px-6 opacity-0 pointer-events-none transition duration-300 md:hidden"
  >
    <nav aria-label="Menu movil" class="grid min-h-[100svh] place-items-center pb-10 pt-20">
      <ul class="m-0 flex list-none flex-col items-center gap-4 p-0">
        {allLinks.map(({ label, href }) => (
          <li>
            <a href={href} aria-current={isActive(href) ? 'page' : undefined} class:list={mobileLinkClass(href)}>
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@700&display=swap" rel="stylesheet" />

<script>
  function initMobileMenu() {
    const btn = document.getElementById('hamburger-btn') as HTMLButtonElement | null;
    const menu = document.getElementById('mobile-menu') as HTMLDivElement | null;
    const line1 = document.getElementById('h-line1') as HTMLSpanElement | null;
    const line2 = document.getElementById('h-line2') as HTMLSpanElement | null;
    const line3 = document.getElementById('h-line3') as HTMLSpanElement | null;

    if (!btn || !menu || !line1 || !line2 || !line3 || btn.dataset.bound === 'true') return;

    const closeMenu = () => {
      btn.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
      menu.classList.add('opacity-0', 'pointer-events-none', '-z-10');
      menu.classList.remove('opacity-100', 'pointer-events-auto', 'z-[60]');
      line1.style.transform = '';
      line2.style.opacity = '';
      line3.style.transform = '';
      document.body.style.overflow = '';
    };

    btn.dataset.bound = 'true';
    closeMenu();

    btn.addEventListener('click', () => {
      const isOpen = btn.getAttribute('aria-expanded') === 'true';

      if (isOpen) {
        closeMenu();
        return;
      }

      btn.setAttribute('aria-expanded', 'true');
      menu.setAttribute('aria-hidden', 'false');
      menu.classList.remove('opacity-0', 'pointer-events-none', '-z-10');
      menu.classList.add('opacity-100', 'pointer-events-auto', 'z-[60]');
      line1.style.transform = 'translateY(8px) rotate(45deg)';
      line2.style.opacity = '0';
      line3.style.transform = 'translateY(-8px) rotate(-45deg)';
      document.body.style.overflow = 'hidden';
    });

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });
  }

  initMobileMenu();
  document.addEventListener('astro:page-load', initMobileMenu);
</script>
