---
const currentYear = new Date().getFullYear();

const navLinks = [
  { label: 'Productos', href: '/products' },
  { label: 'Eventos', href: '/events' },
  { label: 'Contacto', href: '/contact' },
  { label: 'Conocenos', href: '/about' },
];

const legalLinks = [
  { label: 'Pago', href: '/payment' },
  { label: 'Terminos', href: '/terminos-y-condiciones' },
  { label: 'Privacidad', href: '/politica-de-privacidad' },
];

const socials = [
  {
    name: 'Instagram',
    url: '#',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="3" width="18" height="18" rx="5" />
      <circle cx="12" cy="12" r="4" />
      <path d="M17.5 6.5h.01" />
    </svg>`,
  },
  // {
  //   name: 'TikTok',
  //   url: '#',
  //   icon: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
  //     <path d="M16.7 3c.42 2.46 1.78 3.95 4.1 4.1v3.05a7.2 7.2 0 0 1-4.05-1.25v6.15c0 3.2-2.36 5.95-5.77 5.95-3.16 0-5.78-2.37-5.78-5.62 0-3.66 3.46-6.33 7.08-5.46v3.2c-1.7-.55-3.83.3-3.83 2.2 0 1.45 1.13 2.5 2.55 2.5 1.6 0 2.58-1.22 2.58-2.78V3h3.12Z" />
  //   </svg>`,
  // },
  // {
  //   name: 'Facebook',
  //   url: '#',
  //   icon: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
  //     <path d="M14.1 21v-7.4h2.48l.38-2.88H14.1V8.88c0-.83.23-1.4 1.43-1.4h1.52V4.9c-.26-.04-1.17-.11-2.23-.11-2.2 0-3.7 1.34-3.7 3.8v2.13H8.63v2.88h2.49V21h2.98Z" />
  //   </svg>`,
  // },
];
---

<footer data-reveal class="relative z-[100] lg:mt-24 overflow-hidden bg-primary pb-8 pt-20 text-cream">
  <div class="mx-auto grid w-full max-w-7xl gap-12 px-6 md:grid-cols-[1.25fr_0.75fr] md:items-end">
    <div class="relative">
      <a href="/" class="font-[Caveat] text-6xl font-bold leading-none text-cream no-underline transition hover:opacity-80">
        Dulce Aurora
      </a>

      <p class="mt-5 max-w-2xl text-balance text-3xl font-black leading-tight text-cream sm:text-4xl">
        Postres artesanales para celebrar bonito.
      </p>

      <p class="mt-4 max-w-xl text-base font-bold leading-8 text-cream/85">
        Demo de pasteleria artesanal con pedidos personalizados, eventos y detalles dulces.
      </p>

      <div class="mt-7 flex flex-wrap gap-x-6 gap-y-3">
        {socials.map((social) => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={social.name}
            class="motion-press group inline-flex items-center gap-2 text-sm font-black text-cream transition hover:text-secondary"
          >
            <span class="grid h-9 w-9 place-items-center rounded-full bg-cream text-primary transition group-hover:bg-secondary [&_svg]:h-5 [&_svg]:w-5">
              <span set:html={social.icon} />
            </span>
            <span class="border-b-2 border-cream/50 leading-none transition group-hover:border-secondary">{social.name}</span>
          </a>
        ))}
      </div>
    </div>

    <div data-reveal="soft" class="relative rounded-[2rem] border-2 border-cream bg-cream p-5 text-copy shadow-[5px_5px_0_#b81457]">
      <img src="/florero.png" alt="" class="motion-float pointer-events-none absolute -bottom-1 -right-3 w-14 select-none" />

      <nav aria-label="Navegacion del pie de pagina">
        <p class="mb-4 font-[Caveat] text-3xl font-bold text-primary">Explora</p>
        <ul class="m-0 grid list-none grid-cols-2 gap-x-5 gap-y-3 p-0">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="inline-flex border-b-2 border-secondary/70 pb-1 text-sm font-black text-primary transition hover:border-primary hover:text-copy">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="mt-6">
        <p class="text-sm font-black text-copy">Villa Aurora, Mexico</p>
        <div class="mt-3 flex flex-wrap gap-3">
          {legalLinks.map((link) => (
            <a href={link.href} class="text-xs font-bold text-softcopy transition hover:text-primary">
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>

  <div class="mx-auto mt-10 flex w-full max-w-5xl flex-col gap-2 px-6 text-xs font-bold text-cream/75 sm:flex-row sm:items-center sm:justify-between">
    <p>© {currentYear} Dulce Aurora. Sitio demo ficticio.</p>
    <p>Hecho con cuidado y mucho antojo.</p>
  </div>
</footer>
