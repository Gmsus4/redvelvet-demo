---
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import Layout from "../layouts/Layout.astro";

const whatsappBaseUrl = "https://wa.me/525501004827";
const proofMessage = "Hola, ya realice mi transferencia. Te envio mi comprobante.";

const paymentInfo = {
  clabe: "123456789012345678",
  beneficiary: "Lia Moreno Demo",
  institution: "Mercado Pago",
  phone: "+52 55 0100 4827",
};

const paymentSteps = [
  "Copia los datos de transferencia.",
  "Realiza el pago desde tu app bancaria.",
  "Envia el comprobante por WhatsApp para confirmar tu pedido.",
];
---

<Layout title="Pago - Dulce Aurora demo">
  <Navbar />

  <main class="grid w-full place-items-center overflow-hidden px-6 pb-10 pt-28 md:px-20 md:pt-34">
    <section data-reveal class="relative grid w-full max-w-6xl gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 z-0 md:hidden">
        <img src="/corazon.png" alt="" class="motion-float absolute -right-2 top-6 w-8 rotate-12" />
      </div>

      <div class="relative z-10 flex flex-col items-center text-center lg:items-start lg:text-left">
        <p class="mb-4 rounded-full bg-warm px-4 py-2 text-xs font-black uppercase tracking-[0.18em] text-primary lg:bg-secondary/25">
          Datos de pago
        </p>
        <h1 class="max-w-[12ch] font-hero text-[clamp(2.8rem,8vw,5.25rem)] font-normal leading-[0.95] text-secondary md:max-w-[11ch]">
          <span class="text-primary">Aparta</span><br />
          tu pedido.
        </h1>
        <p class="mt-6 max-w-md text-base font-bold leading-8 text-copy md:text-lg">
          Usa estos datos para transferir. Despues envia tu comprobante por WhatsApp para confirmar fecha, producto y detalles.
        </p>

        <div class="mt-7 grid w-full gap-3 sm:max-w-md">
          {paymentSteps.map((step, index) => (
            <div data-reveal="soft" style={`--reveal-delay: ${index * 70}ms`} class="flex items-center gap-3 rounded-2xl bg-cream/85 p-4">
              <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-primary text-xs font-black text-white">{index + 1}</span>
              <p class="text-sm font-black leading-6 text-copy">{step}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="relative z-10 grid gap-4 rounded-[2.5rem] border border-primary/10 bg-white/45 p-5 backdrop-blur-sm md:p-7">
        <div class="rounded-[1.75rem] bg-cream/85 p-4">
          <p class="text-xs font-black uppercase tracking-[0.14em] text-primary">Cuenta CLABE</p>
          <div class="mt-2 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <p class="break-all text-xl font-black leading-7 text-copy">{paymentInfo.clabe}</p>
            <button type="button" data-copy={paymentInfo.clabe} class="copy-button motion-press inline-flex min-h-10 cursor-pointer items-center justify-center rounded-full bg-primary px-5 text-xs font-black text-white transition hover:bg-primary/90">
              Copiar
            </button>
          </div>
        </div>

        <div class="rounded-[1.75rem] bg-cream/85 p-4">
          <p class="text-xs font-black uppercase tracking-[0.14em] text-primary">Beneficiario</p>
          <div class="mt-2 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <p class="text-xl font-black leading-7 text-copy">{paymentInfo.beneficiary}</p>
            <button type="button" data-copy={paymentInfo.beneficiary} class="copy-button motion-press inline-flex min-h-10 cursor-pointer items-center justify-center rounded-full bg-primary px-5 text-xs font-black text-white transition hover:bg-primary/90">
              Copiar
            </button>
          </div>
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
          <div class="rounded-[1.75rem] bg-secondary/12 p-4">
            <p class="text-xs font-black uppercase tracking-[0.14em] text-primary">Institucion</p>
            <p class="mt-2 text-lg font-black leading-7 text-copy">{paymentInfo.institution}</p>
          </div>
          <div class="rounded-[1.75rem] bg-secondary/12 p-4">
            <p class="text-xs font-black uppercase tracking-[0.14em] text-primary">Telefono</p>
            <p class="mt-2 text-lg font-black leading-7 text-copy">{paymentInfo.phone}</p>
          </div>
        </div>

        <a href={`${whatsappBaseUrl}?text=${encodeURIComponent(proofMessage)}`} target="_blank" rel="noopener noreferrer" class="motion-press inline-flex min-h-12 w-full items-center justify-center rounded-full bg-primary px-8 text-sm font-black text-white transition hover:bg-primary/90">
          Enviar comprobante
        </a>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    function initCopyButtons() {
      const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('.copy-button[data-copy]'));

      buttons.forEach((button) => {
        if (button.dataset.bound === 'true') return;

        button.dataset.bound = 'true';
        const originalText = button.textContent || 'Copiar';

        button.addEventListener('click', async () => {
          const value = button.dataset.copy || '';

          try {
            await navigator.clipboard.writeText(value);
            button.textContent = 'Copiado';
            window.setTimeout(() => {
              button.textContent = originalText;
            }, 1400);
          } catch {
            button.textContent = 'No copiado';
            window.setTimeout(() => {
              button.textContent = originalText;
            }, 1400);
          }
        });
      });
    }

    initCopyButtons();
    document.addEventListener('astro:page-load', initCopyButtons);
  </script>
</Layout>
