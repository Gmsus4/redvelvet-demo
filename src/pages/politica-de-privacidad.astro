---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const currentYear = new Date().getFullYear();

const sections = [
  {
    title: 'Que informacion recopilamos',
    description: 'En esta demo se muestran campos ficticios como nombre, telefono, correo y direccion para representar un flujo de contacto.',
  },
  {
    title: 'Para que usamos tus datos',
    description: 'La informacion descrita aqui es de ejemplo y representa como un negocio podria explicar el uso de datos de contacto.',
  },
  {
    title: 'Como cuidamos tu informacion',
    description: 'Este texto es demostrativo. En un proyecto real, las politicas deberian adaptarse al manejo verdadero de informacion.',
  },
  {
    title: 'Mensajes y redes sociales',
    description: 'Si un sitio real enlaza redes sociales o mensajeria, tambien podrian aplicar las politicas de esas plataformas.',
  },
  {
    title: 'Eliminacion de datos',
    description: 'En una version real, aqui se indicaria como solicitar acceso, correccion o eliminacion de datos personales.',
  },
  {
    title: 'Cambios a esta politica',
    description: 'Podemos actualizar esta politica cuando sea necesario. La version vigente estara publicada en esta misma pagina.',
  },
];
---

<Layout title="Politica de privacidad - Dulce Aurora demo">
  <Navbar />

  <main class="grid w-full place-items-center px-6 pb-10 pt-28 md:px-10 md:pt-34">
    <div class="grid w-full max-w-4xl gap-10">
      <section data-reveal class="flex w-full flex-col items-center text-center">
        <p class="mb-4 rounded-full bg-secondary/25 px-4 py-2 text-xs font-black uppercase tracking-[0.18em] text-primary">
          Privacidad
        </p>
        <h1 class="max-w-[13ch] font-hero text-[clamp(2.6rem,8vw,4.8rem)] font-normal leading-[0.98] text-secondary mb-12">
          <span class="text-primary">Tus datos</span><br />
          se usan para cuidar tu pedido.
        </h1>
        <p class="text-base font-bold leading-8 text-copy">
          Esta politica es ficticia y forma parte de una demo. Explica de manera ilustrativa como podria presentarse el manejo de datos en un sitio de pasteleria.
        </p>
        <p class="text-sm font-bold text-softcopy">
          Ultima actualizacion: {currentYear}
        </p>
      </section>

      <section class="grid w-full gap-3">
        {sections.map((section, index) => (
          <article data-reveal="soft" style={`--reveal-delay: ${Math.min(index, 6) * 55}ms`} class="motion-pop grid grid-cols-[auto_1fr] gap-4 rounded-3xl border border-primary/10 bg-white/50 px-5 py-4 backdrop-blur-sm">
            <span class="pt-1 font-[Caveat] text-3xl font-bold leading-none text-primary">
              {String(index + 1).padStart(2, '0')}
            </span>
            <div>
              <h2 class="text-sm font-black uppercase leading-5 text-primary">{section.title}</h2>
              <p class="mt-2 text-sm font-bold leading-7 text-copy">{section.description}</p>
            </div>
          </article>
        ))}
      </section>

      <section data-reveal class="flex w-full flex-col gap-4 rounded-3xl border border-primary/15 bg-secondary/18 p-5 sm:flex-row sm:items-center sm:justify-between">
        <p class="max-w-md text-base font-bold leading-8 text-copy">
          Si tienes dudas sobre el manejo de tu informacion, puedes escribirnos directamente.
        </p>
        <a href="/contact" class="motion-press inline-flex w-fit rounded-full bg-primary px-6 py-3 text-sm font-black text-white transition hover:bg-primary/90">
          Contactar
        </a>
      </section>
    </div>
  </main>

  <Footer />
</Layout>
