---
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import Layout from "../layouts/Layout.astro";

const gallery = [
  { src: "/products/pasteles.webp", alt: "Pastel personalizado para evento" },
  { src: "/products/mostachon.webp", alt: "Mesa de postres con mostachon" },
  { src: "/products/cheesecake.webp", alt: "Pastel decorado para celebracion" },
  { src: "/products/cupcakes.webp", alt: "Cupcakes para mesa dulce" },
  { src: "/products/fresas.webp", alt: "Fresas cubiertas con chocolate" },
];

const options = ["Pasteles personalizados", "Mesa dulce", "Postres individuales", "Diseno por tematica"];

const includes = [
  { label: "Base", value: "Pastel principal o mesa dulce" },
  { label: "Detalle", value: "Colores, tematica y presentacion" },
  { label: "Porciones", value: "Cantidad sugerida segun invitados" },
  { label: "Extras", value: "Postres individuales para complementar" },
];

const steps = [
  { title: "Cuentanos", description: "Fecha, lugar, numero aproximado de personas y tipo de celebracion." },
  { title: "Cotizamos", description: "Te proponemos opciones de postres, cantidades y estilo visual." },
  { title: "Apartas", description: "Confirmamos fecha y empezamos a preparar los detalles de tu mesa." },
];
---

<Layout title="Eventos - Dulce Aurora demo">
  <Navbar />
  <main class="grid w-full place-items-center overflow-hidden px-6 pb-10 pt-28 md:px-20 md:pt-34">
    <div class="grid w-full max-w-6xl gap-12">
      <section data-reveal class="relative grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
        <div aria-hidden="true" class="pointer-events-none absolute inset-0 z-0 md:hidden">
          <img src="/derecha/pastel.png" alt="" class="motion-float absolute -right-6 top-[30%] w-18 rotate-6" />
          <img src="/izquierda/decoracion2.png" alt="" class="motion-float-slow absolute -left-1 top-3 w-10 -rotate-12" />
          <img src="/derecha/corazon1.png" alt="" class="motion-float absolute left-4 bottom-[42%] w-5 rotate-12" />
        </div>

        <div class="relative z-10 flex flex-col items-center text-center lg:items-start lg:text-left">
          <p class="mb-4 rounded-full bg-warm px-4 py-2 text-xs font-black uppercase tracking-[0.18em] text-primary lg:bg-secondary/25">
            Eventos dulces
          </p>
          <h1 class="max-w-[12ch] font-hero text-[clamp(2.8rem,8vw,4.50rem)] font-normal leading-[0.95] text-secondary md:max-w-[11ch]">
            <span class="text-primary">Mesas dulces</span><br />
            y pasteles para tu evento.
          </h1>
          <p class="mt-6 max-w-md text-base font-bold leading-8 text-copy md:text-lg">
            Armamos propuestas para cumpleanos, bodas, reuniones, aniversarios y celebraciones especiales.
          </p>
          <div class="mt-7 flex flex-wrap justify-center gap-2 lg:justify-start">
            {options.map((option) => (
              <span class="rounded-full border border-primary/12 bg-warm/20 px-3.5 py-2 text-xs font-black text-softcopy backdrop-blur-sm lg:bg-cream/80">
                {option}
              </span>
            ))}
          </div>
          <a href="/contact" class="motion-press mt-8 inline-flex min-h-12 items-center justify-center rounded-full bg-primary px-8 text-sm font-black text-white transition hover:bg-primary/90">
            Cotizar evento
          </a>
        </div>

        <div class="relative z-10 grid grid-cols-2 gap-3 rounded-[2rem] bg-warm/20 p-2 sm:grid-cols-3 lg:bg-transparent lg:p-0">
          {gallery.map((image, index) => (
            <figure data-reveal="image" style={`--reveal-delay: ${index * 70}ms`} class:list={[
              "motion-pop overflow-hidden rounded-[1.5rem] border border-primary/10 bg-white p-1",
              index === 0 ? "col-span-2 sm:row-span-2" : "",
            ]}>
              <img src={image.src} alt={image.alt} class="aspect-square h-full w-full rounded-[1.15rem] object-cover" />
            </figure>
          ))}
        </div>
      </section>

      <section data-reveal class="grid gap-8">
        <div class="rounded-[2.5rem] border border-primary/10 bg-white/45 p-5 backdrop-blur-sm md:p-8">
          <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
            <div>
              <p class="mb-4 inline-block rounded-full bg-warm px-4 py-2 text-xs font-black uppercase tracking-[0.18em] text-primary">
                Cotizacion
              </p>
              <h2 class="max-w-[15ch] font-hero text-4xl font-normal leading-none text-primary sm:text-5xl">
                Armamos la mesa segun tu evento.
              </h2>
            </div>
            <p class="max-w-md text-sm font-bold leading-7 text-copy">
              No todos los eventos necesitan lo mismo. Ajustamos cantidades, estilos y tipo de postre segun invitados, horario y forma de servir.
            </p>
          </div>

          <div class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
            {includes.map((item, index) => (
              <article data-reveal="soft" style={`--reveal-delay: ${index * 60}ms`} class="motion-pop min-h-36 rounded-[1.75rem] bg-cream/85 p-4">
                <p class="font-[Caveat] text-3xl font-bold leading-none text-secondary">{item.label}</p>
                <p class="mt-4 text-sm font-black leading-6 text-copy">{item.value}</p>
              </article>
            ))}
          </div>
        </div>

        <div class="grid gap-4 lg:grid-cols-[1fr_auto_1fr_auto_1fr] lg:items-center">
          {steps.map((step, index) => (
            <>
              <article data-reveal="soft" style={`--reveal-delay: ${index * 80}ms`} class="rounded-[2rem] bg-secondary/12 p-5 text-center">
                <span class="mx-auto grid h-12 w-12 place-items-center rounded-full bg-primary font-black text-white">{index + 1}</span>
                <h3 class="mt-4 text-sm font-black uppercase tracking-[0.12em] text-primary">{step.title}</h3>
                <p class="mt-2 text-sm font-bold leading-7 text-copy">{step.description}</p>
              </article>
              {index < steps.length - 1 && <span class="hidden h-px w-10 bg-primary/40 lg:block"></span>}
            </>
          ))}
        </div>

        <div class="flex justify-center">
          <a href="/contact" class="motion-press inline-flex min-h-12 w-full items-center justify-center rounded-full bg-primary px-8 text-sm font-black text-white transition hover:bg-primary/90 sm:w-fit">
            Quiero cotizar mi evento
          </a>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
